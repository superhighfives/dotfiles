# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Icon must end with two \r
Icon


# IDE
.vscode

# Secrets - NEVER commit these
.secrets

# Claude Code local settings
.claude/settings.local.json
.claude/plans/

# GitHub CLI auth tokens (managed by `gh auth login`)
.config/gh/hosts.yml

# NAPS2 - only track config and profiles
.config/naps2/*
!.config/naps2/config.xml
!.config/naps2/profiles.xml

# Windsurf - only track User settings, keybindings, and snippets
Library/Application Support/Windsurf/*
!Library/Application Support/Windsurf/User/
Library/Application Support/Windsurf/User/*
!Library/Application Support/Windsurf/User/settings.json
!Library/Application Support/Windsurf/User/keybindings.json
!Library/Application Support/Windsurf/User/snippets/
