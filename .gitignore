# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Icon must end with two \r
Icon


# IDE
.vscode
.zed/

# Secrets - NEVER commit these
.secrets

# Claude Code local settings
.claude/settings.local.json
.claude/plans/

# skills CLI global lock file - symlinked from ~/.agents/.skill-lock.json,
# may contain private skill URLs (see ~/.skills.local)
.agents/.skill-lock.json

# Wrangler - local cache
.wrangler/

# Windsurf - app state (Windsurf removed from stack)
Library/Application Support/Windsurf/

# --- .config: allowlist model (default-deny) ---
# Everything under .config/ is ignored unless re-included with a `!` line
# below, so a newly installed tool's credentials can't silently land in this
# public repo. To start tracking a config: add `!.config/<name>/` under the
# tracked list, then `git add`. Run scripts/config-drift.sh to list configs on
# disk that aren't allowlisted or acknowledged yet.
.config/*

# Tracked configs (re-included)
!.config/atuin/
!.config/biome.json
!.config/ghostty/
!.config/git/
!.config/pnpm/
!.config/uv/

# gh - track config, but never the auth tokens
!.config/gh/
.config/gh/hosts.yml

# opencode - track config, but not the generated skill commands
!.config/opencode/
.config/opencode/commands/*.md

# zed - track settings, but not runtime state
!.config/zed/
.config/zed/prompts/
.config/zed/themes/

# naps2 - track config and profiles only
!.config/naps2/
.config/naps2/*
!.config/naps2/config.xml
!.config/naps2/profiles.xml

# Acknowledged ignores — intentionally untracked, listed explicitly so
# scripts/config-drift.sh treats them as decided rather than as new drift.
# Stripe CLI - config.toml holds API credentials
.config/stripe/
# Devin - workspace, not config
.config/devin/
# Raycast - app runtime state
.config/raycast/
# macOS Finder metadata
.config/.DS_Store
# cog - update-checker runtime state
.config/cog/

# Local machine overlays - never commit
*.local
*.local.*
.*.local
.*.local.*
# But keep the tracked .local/ directory (XDG-style local binaries)
!.local/
!.local/**

# Internal docs (specs, plans, scratch)
docs/
