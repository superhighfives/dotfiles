# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Icon must end with two \r
Icon


# IDE
.vscode
.zed/

# Secrets - NEVER commit these
.secrets

# Claude Code local settings
.claude/settings.local.json
.claude/plans/

# OpenCode commands generated by install.sh from .agents/skills/<name>/SKILL.md
.config/opencode/commands/*.md

# GitHub CLI auth tokens (managed by `gh auth login`)
.config/gh/hosts.yml

# Devin - don't track the workspace
.config/devin/

# Raycast - runtime state (settings live in Raycast.rayconfig)
.config/raycast/ai/
.config/raycast/extensions/

# Zed - runtime state created on first launch
.config/zed/prompts/
.config/zed/themes/

# Windsurf - app state (Windsurf removed from stack)
Library/Application Support/Windsurf/

# NAPS2 - only track config and profiles
.config/naps2/*
!.config/naps2/config.xml
!.config/naps2/profiles.xml

# Local machine overlays - never commit
*.local
*.local.*
.*.local
.*.local.*
# But keep the tracked .local/ directory (XDG-style local binaries)
!.local/
!.local/**

# Internal docs (specs, plans, scratch)
docs/
