{
	"icon_theme": {
		"mode": "light",
		"light": "Zed (Default)",
		"dark": "Zed (Default)"
	},
	"agent_servers": {
		"claude-acp": {
			"type": "registry"
		}
	},
	"cli_default_open_behavior": "existing_window",
	"theme": {
		"mode": "dark",
		"light": "One Light",
		"dark": "Ayu Darker"
	},
	"ui_font_family": ".SystemUIFont",
	"buffer_font_family": "Geist Mono",
	"ui_font_size": 15,
	"buffer_font_size": 13,

	"soft_wrap": "editor_width",
	"show_whitespaces": "boundary",
	"current_line_highlight": "gutter",
	"cursor_shape": "block",
	"relative_line_numbers": "disabled",
	"scrollbar": {
		"show": "auto",
		"git_diff": true,
		"diagnostics": "all"
	},

	"agent": {
		"sidebar_side": "left",
  "default_profile": "write",
		"inline_assistant_model": {
			"provider": "anthropic",
			"model": "claude-sonnet-4-5"
		}
	},

	"edit_predictions": {
		"provider": "zed",
		"mode": "eager",
		"disabled_globs": [
			"**/.env*",
			"**/.dev.vars",
			"**/*.pem",
			"**/*.key",
			"**/*.cert",
			"**/*.crt",
			"**/secrets.yml"
		]
	},

	"languages": {
		"JavaScript": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": { "source.organizeImports.biome": true }
		},
		"TypeScript": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": { "source.organizeImports.biome": true }
		},
		"TSX": {
			"formatter": { "language_server": { "name": "biome" } },
			"code_actions_on_format": { "source.organizeImports.biome": true }
		},
		"JSON": {
			"formatter": { "language_server": { "name": "biome" } }
		},
		"JSONC": {
			"formatter": { "language_server": { "name": "biome" } }
		},
		"Python": {
			"formatter": { "language_server": { "name": "ruff" } },
			"code_actions_on_format": {
				"source.fixAll.ruff": true,
				"source.organizeImports.ruff": true
			}
		},
		"Markdown": {
			"soft_wrap": "editor_width",
			"format_on_save": "off"
		}
	},

	"auto_install_extensions": {
		"astro": true,
		"biome": true,
		"mdx": true
	},

	"telemetry": {
		"diagnostics": false,
		"metrics": false,
		"anthropic_retention": false
	}
}
