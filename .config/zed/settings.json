{
  "code_lens": "off",
  "vim_mode": false,
  "terminal": {
    "copy_on_select": true,
  },
  "icon_theme": "Zed (Default)",
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "mode": "acceptEdits",
      },
      "type": "registry",
    },
  },
  "cli_default_open_behavior": "existing_window",
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Ayu Darker",
  },
  "ui_font_family": ".SystemUIFont",
  "buffer_font_family": "Geist Mono",
  "ui_font_size": 15,
  "buffer_font_size": 13,

  "soft_wrap": "editor_width",
  "show_whitespaces": "boundary",
  "current_line_highlight": "gutter",
  "cursor_shape": "block",
  "scrollbar": {
    "show": "auto",
    "git_diff": true,
    "diagnostics": "all",
  },

  "format_on_save": "on",

  "agent": {
    "sidebar_side": "left",
    "default_profile": "write",
    "inline_assistant_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-5",
    },
  },

  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "disabled_globs": [
      "**/.env*",
      "**/.dev.vars",
      "**/*.pem",
      "**/*.key",
      "**/*.cert",
      "**/*.crt",
      "**/secrets.yml",
    ],
  },

  "lsp": {
    "tsgo": {
      "settings": {
        "package_version": "7.0.0-dev.20251201.1",
      },
    },
    "vtsls": {
      "settings": {
        "typescript": {
          "tsserver": {
            "maxTsServerMemory": 8192,
          },
        },
        "javascript": {
          "tsserver": {
            "maxTsServerMemory": 8192,
          },
        },
      },
    },
  },

  "languages": {
    "JavaScript": {
      "language_servers": ["vtsls", "eslint", "biome"],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": { "source.organizeImports.biome": true },
    },
    "TypeScript": {
      "enable_language_server": true,
      "inlay_hints": {
        "enabled": true,
      },
      "language_servers": ["vtsls", "eslint", "biome"],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": { "source.organizeImports.biome": true },
    },
    "TSX": {
      "language_servers": ["vtsls", "eslint", "biome"],
      "formatter": { "language_server": { "name": "biome" } },
      "code_actions_on_format": { "source.organizeImports.biome": true },
    },
    "JSON": {
      "formatter": "auto",
    },
    "JSONC": {
      "formatter": "auto",
    },
    "Python": {
      "formatter": { "language_server": { "name": "ruff" } },
      "code_actions_on_format": {
        "source.fixAll.ruff": true,
        "source.organizeImports.ruff": true,
      },
    },
    "Markdown": {
      "soft_wrap": "editor_width",
      "format_on_save": "off",
    },
    "CSS": {
      "language_servers": ["tailwindcss-language-server"],
    },
  },

  "auto_install_extensions": {
    "astro": true,
    "ayu-darker": true,
    "biome": true,
    "mdx": true,
    "tsgo": true,
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
    "anthropic_retention": false,
  },

  "diagnostics": {
    "inline": {
      "enabled": true,
      "max_severity": null,
    },
  },

  "hard_tabs": false,
  "tab_size": 2,
}
