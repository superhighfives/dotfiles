// Zed keymap - https://zed.dev/docs/key-bindings
// Zed's default keymap is already close to VS Code's; we only override the
// pieces that diverged in Windsurf.
[
  {
    "bindings": {
      // Match Windsurf: cmd+t opens the file finder, cmd+p opens project symbols.
      // (Zed default is the opposite.)
      "cmd-t": "file_finder::Toggle",
      "cmd-p": "project_symbols::Toggle",

      // Match Windsurf: shift+cmd+g goes to previous search match.
      "shift-cmd-g": "search::SelectPreviousMatch",

      // Match Windsurf: cmd+shift+l selects all matches of the current selection.
      "cmd-shift-l": "editor::SelectAllMatches"
    }
  },
  {
    // Forward common navigation keys to the built-in terminal so cmd+arrow
    // behaves the way it does in iTerm/Ghostty.
    "context": "Terminal",
    "bindings": {
      "cmd-left": ["terminal::SendKeystroke", "home"],
      "cmd-right": ["terminal::SendKeystroke", "end"],
      "shift-cmd-left": ["terminal::SendKeystroke", "shift-home"],
      "shift-cmd-right": ["terminal::SendKeystroke", "shift-end"],
      // Backslash-newline for soft line continuation, like Windsurf.
      "shift-enter": ["terminal::SendText", "\\\n"]
    }
  }
]
